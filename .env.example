# ═══════════════════════════════════════════════════════════════════
# ClubMillies — copy to .env and replace placeholders (never commit .env)
# ═══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
API_SECRET_KEY=change-me-to-a-long-random-string

# ── MetaTrader 5 (optional; accounts can also be added in dashboard) ─
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=JustMarkets-Demo
MT5_ACCOUNT_NAME=MT5 Account
MT5_SYMBOL=XAUUSDm
MT5_TIMEFRAME=M15
# For scripts/mt5_smoke_test.py only:
# MT5_TEST_VOLUME=0.01

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ENABLE_POLLING=false
# TELEGRAM_TRADE_CLOSE_AI=false

# ── Anthropic (Claude) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Twitter / X (official API — use Bearer, not your password) ─────
TWITTER_BEARER_TOKEN=
# TWITTER_SEARCH_QUERIES=gold OR XAUUSD,DXY OR "us dollar index"

# ── Market intel (no Twitter login required) ───────────────────────
GOOGLE_NEWS_QUERIES=gold price,XAUUSD,DXY US Dollar

# ── Trading ────────────────────────────────────────────────────────
MIN_CONFLUENCE_FLOOR=5

# ── Optional: auto-create demo accounts on first run (usually false) ─
# CREATE_PAPER_DEMO=false
# PAPER_BALANCE=10000
# DEFAULT_SYMBOL=XAUUSDm
# DEFAULT_PROFILE=SNIPER

# ── SociaVault (optional X/Twitter search — 1 credit per request) ────
# Get key from https://sociavault.com/dashboard — never commit real keys.
# SOCIAVAULT_API_KEY=
# SOCIAVAULT_BASE_URL=https://api.sociavault.com
# SOCIAVAULT_SEARCH_QUERIES=gold OR XAUUSD,DXY,"federal reserve"
# If SOCIAVAULT_SEARCH_QUERIES is empty, TWITTER_SEARCH_QUERIES is used, else defaults.

# Default search text for the dashboard "Fetch new tweets" button (one SociaVault request per click)
# INTEL_DEFAULT_QUERY=gold OR XAUUSD OR DXY OR war OR "us dollar index"
